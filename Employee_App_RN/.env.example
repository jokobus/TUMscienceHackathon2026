# WEave Employee App — environment template. Copy to .env and adjust.
# EXPO_PUBLIC_* are inlined at build time — set before building/starting.

# REST origin (no trailing slash). All /api & /internal calls use this.
#   Local / iOS simulator : http://localhost:8000
#   Android emulator      : http://10.0.2.2:8000
#   Production            : https://api.your-domain.com
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional: full chat WebSocket URL. If unset, derived from the REST origin
# (http→ws / https→wss) + "/ws/chat". Override only if the WS host/path differs.
# EXPO_PUBLIC_WS_URL=wss://api.your-domain.com/ws/chat
