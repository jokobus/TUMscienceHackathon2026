# WEave reverse proxy — automatic HTTPS via Let's Encrypt.
# {$DOMAIN_APP} and {$DOMAIN_API} are read from the environment (see docker-compose.yml).

# Würth dashboard (Next.js)
{$DOMAIN_APP} {
	encode gzip zstd
	reverse_proxy dashboard:3000
}

# Student web app (Next.js) — for audience/browser access
{$DOMAIN_STUDENT} {
	encode gzip zstd
	reverse_proxy student:3000
}

# Backend API + WebSocket (FastAPI). Caddy proxies WebSocket upgrades transparently.
{$DOMAIN_API} {
	encode gzip zstd
	reverse_proxy api:8000
}
