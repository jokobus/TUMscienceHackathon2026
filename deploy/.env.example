# ── WEave deployment config — copy to deploy/.env and fill in ─────────────────

# Public domains (point all three A-records at your Hetzner server's IP).
DOMAIN_APP=dash.weave.example.com       # Würth dashboard
DOMAIN_STUDENT=app.weave.example.com    # Student web app (audience access)
DOMAIN_API=api.weave.example.com        # Backend REST + WebSocket

# Database (change the password for production!).
POSTGRES_USER=weave
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=weave

# Backend secrets.
JWT_SECRET=generate-a-long-random-string
SEED_ON_STARTUP=true            # seeds demo data on first boot; set false after

# AI keys (optional).
ANTHROPIC_API_KEY=              # backend AI features (Backend/app/ai.py)
OPENROUTER_API_KEY=             # dashboard /api/assistant route

# Dashboard data source:
#   false → live, DB-backed via https://${DOMAIN_API} (recommended — atomic data,
#           the dashboard auto-logs-in as a demo employee). This is the default.
#   true  → offline mock data (no backend needed; emergency fallback for the pitch)
NEXT_PUBLIC_USE_MOCKS=false
