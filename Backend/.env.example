# ── WEave backend configuration ───────────────────────────────────────────────
# Copy to `.env` and adjust. docker-compose injects DATABASE_URL automatically.

# Database. Postgres in Docker; falls back to a local SQLite file if unset.
#   Postgres : postgresql+psycopg://weave:weave@db:5432/weave
#   SQLite   : sqlite:///./weave.db
DATABASE_URL=postgresql+psycopg://weave:weave@localhost:5432/weave

# Auth — CHANGE THIS in any real deployment.
JWT_SECRET=dev-secret-change-me
JWT_EXPIRE_MINUTES=10080

# CORS — comma-separated origins the frontends are served from. "*" allows all.
CORS_ORIGINS=*

# Seed the demo data on startup when the DB is empty.
SEED_ON_STARTUP=true

# Optional: Anthropic key enables real LLM event-search + opportunity assistant.
# Without it, those endpoints fall back to deterministic heuristics.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-fable-5
