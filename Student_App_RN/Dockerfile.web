# ── Student app — web build (Expo export) served as a static SPA ──────────────
# A browser-accessible backup of the React Native app for jurors who can't run
# the mobile build. Native-only features (camera/QR) degrade gracefully on web.
FROM node:22-alpine AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
# Baked at build time → the web app talks to this backend.
ARG EXPO_PUBLIC_API_BASE_URL=
ENV EXPO_PUBLIC_API_BASE_URL=$EXPO_PUBLIC_API_BASE_URL
RUN npx expo export -p web

FROM caddy:2-alpine
COPY --from=build /app/dist /srv
# SPA fallback: serve index.html for client-routed paths.
RUN printf ':3000 {\n\troot * /srv\n\tencode gzip zstd\n\ttry_files {path} /index.html\n\tfile_server\n}\n' > /etc/caddy/Caddyfile
EXPOSE 3000
