# Copy to .env.local and adjust when wiring the real backend.

# When "true" (or unset in dev), the dashboard serves mock data from lib/mocks.ts.
# Set to "false" to route every call through the real backend (lib/api.ts).
NEXT_PUBLIC_USE_MOCKS=true

# Base URL of the FastAPI backend. All /internal/** calls are prefixed with this.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# WebSocket endpoint for the Communication Hub (Master §7).
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/chat
